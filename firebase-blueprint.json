{
  "entities": {
    "Order": {
      "title": "Order Request",
      "description": "An order or consultation request from a customer",
      "type": "object",
      "properties": {
        "customerName": { "type": "string", "description": "Customer name" },
        "phoneNumber": { "type": "string", "description": "Customer phone number" },
        "address": { "type": "string", "description": "Customer delivery/consultation address" },
        "items": { 
          "type": "array", 
          "description": "List of items in the cart",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "status": { 
          "type": "string", 
          "enum": ["pending", "assigned", "completed"],
          "description": "Current status of the order"
        },
        "assignedStaffId": { "type": "string", "description": "ID of the staff assigned to this order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phoneNumber", "address", "items", "status", "createdAt"]
    },
    "Staff": {
      "title": "Sales Staff",
      "description": "Staff member who handles orders",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name", "phone"]
    }
  },
  "firestore": {
    "orders": {
      "schema": "Order",
      "description": "Collection of order/consultation requests"
    },
    "staff": {
      "schema": "Staff",
      "description": "Collection of sales staff members"
    }
  }
}
