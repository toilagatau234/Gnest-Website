rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'toilagatau234@gmail.com' && request.auth.token.email_verified == true
      );
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 200 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 15 &&
             data.address is string && data.address.size() > 0 && data.address.size() <= 1000 &&
             data.items is list && data.items.size() > 0 &&
             data.status in ['pending', 'assigned', 'completed'] &&
             data.createdAt == request.time;
    }

    match /orders/{orderId} {
      // Anyone can submit a consultation request
      allow create: if isValidOrder(request.resource.data);
      
      // Only admins can see and manage orders
      allow read, update: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
