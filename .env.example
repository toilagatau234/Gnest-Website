# Public site URL used by Next.js metadata and canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Project URL (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable/anon key used by browser and SSR clients
# Keep this public-safe key only. Do not put the service role key here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Supabase service role key used only by server-side admin actions
# Never expose this key to the browser and never commit real secrets.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: enable server timing logs in development only
ADMIN_TIMING_LOGS=0
